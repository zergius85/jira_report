# =============================================
# JIRA REPORT SYSTEM — КОНФИГУРАЦИЯ
# =============================================
# Версия конфигурации (не менять)
CONFIG_VERSION=2.3

# Скопируйте этот файл в .env и заполните значения

# --- ПОДКЛЮЧЕНИЕ К JIRA (ОБЯЗАТЕЛЬНО) ---
JIRA_SERVER=https://your-jira-server.com
JIRA_USER=your.email@company.com
JIRA_PASS=your_password_or_token

# --- НАСТРОЙКИ ОТЧЁТОВ ---
# Проекты для исключения из отчётов (через запятую, без пробелов)
EXCLUDED_PROJECTS=TEST,DEMO,ARCHIVE

# ID статусов "Закрыт"/"Closed" (автоматически определяется при первом запуске)
# Оставьте пустым для авто-определения
CLOSED_STATUS_IDS=

# Пользователи, для которых статус "Закрыт" не считается ошибкой (через запятую)
EXCLUDED_ASSIGNEE_CLOSE=holin,admin

# --- БЕЗОПАСНОСТЬ ---
# Отключить проверку SSL (true/false) — ТОЛЬКО для внутренних серверов!
# ВНИМАНИЕ: При SSL_VERIFY=false данные передаются без проверки сертификата.
# Используйте только во внутренней сети с доверенными серверами.
# Для production рекомендуется использовать valid SSL сертификаты.
SSL_VERIFY=false

# =============================================
# TELEGRAM (для уведомлений)
# =============================================
# Получить токен бота: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Webhook URL (опционально, для push-уведомлений)
TELEGRAM_WEBHOOK_URL=

# =============================================
# EMAIL (SMTP для отправки отчётов)
# =============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Jira Report <noreply@jira-report.local>

# =============================================
# БАЗА ДАННЫХ (для истории отчётов)
# =============================================
# По умолчанию SQLite в корне проекта
# DATABASE_URL=sqlite:///jira_report.db
# Для PostgreSQL: postgresql://user:pass@localhost/jira_report
DATABASE_URL=

# =============================================
# РЕЖИМ РАБОТЫ (НЕ МЕНЯТЬ БЕЗ НУЖДЫ)
# =============================================
# FLASK_ENV=production — для продакшена (порт 5000)
# FLASK_ENV=development — для разработки (порт 5001, по умолчанию)
# FLASK_ENV=

# Логирование: DEBUG (dev) или INFO (prod)
# LOG_LEVEL=
